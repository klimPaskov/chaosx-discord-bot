# Create a Discord application + bot, then put its bot token here.
# Never paste this into Discord chat or commit a real token.
CHAOSX_DISCORD_TOKEN=paste-token-here
CHAOSX_APPLICATION_DESCRIPTION=Ask ChaosX questions about Chaos Redux events, scenarios, mechanics, testing, and mod info.
CHAOSX_OWNER_ID=789502982122373150

# ChaosX is private to the Chaos Redux server. It leaves any other guild it is added to.
CHAOSX_ALLOWED_GUILD_ID=1395459671598436533

# Optional: guild-scoped command registration for fast staging.
# Set this to the server ID during development.
CHAOSX_COMMAND_GUILD_ID=1395459671598436533

# Chaos Redux repo and Hermes runtime.
CHAOSX_CHAOS_REDUX_REPO=/home/klim/projects/chaos_redux
CHAOSX_HERMES_BIN=/home/klim/.local/bin/hermes
CHAOSX_HERMES_PROFILE=chaos_redux

# Focus trees, event chains, and scripted-GUI previews use the official Python MCP client to call HOI4 Agent Tools.
# Override this when the live HOI4 mod checkout differs from CHAOSX_CHAOS_REDUX_REPO.
CHAOSX_FOCUS_TREE_REPO=
CHAOSX_FOCUS_TREE_GRAPHS_ENABLED=true
CHAOSX_FOCUS_MCP_COMMAND=npx
CHAOSX_FOCUS_MCP_ARGS=-y hoi4-agent-tools@1.2.0
CHAOSX_FOCUS_MCP_CONFIG_PATH=/home/klim/.config/hoi4-agent-tools/config.json
CHAOSX_FOCUS_MCP_WORKSPACE_ID=
CHAOSX_FOCUS_MCP_WORKSPACE_NAME=chaos_redux
CHAOSX_FOCUS_MCP_TIMEOUT_SECONDS=300
CHAOSX_FOCUS_TREE_MAX_GRAPHS=6
CHAOSX_FOCUS_TREE_REVIEW_SCALE=0.5
CHAOSX_FOCUS_TREE_MAX_ATTACHMENT_BYTES=8000000
CHAOSX_EVENT_CHAIN_GRAPHS_ENABLED=true
CHAOSX_EVENT_CHAIN_MAX_DEPTH=2
CHAOSX_EVENT_CHAIN_MAX_NODES=60
CHAOSX_EVENT_CHAIN_GRAPHVIZ_COMMAND=dot
CHAOSX_SCRIPTED_GUI_PREVIEWS_ENABLED=true
CHAOSX_SCRIPTED_GUI_MAX_PREVIEWS=2
CHAOSX_SCRIPTED_GUI_PREVIEW_WIDTH=1280
CHAOSX_SCRIPTED_GUI_PREVIEW_HEIGHT=720

# SQLite state DB for audit records and command/job mappings.
CHAOSX_DB_PATH=./chaosx.db
CHAOSX_GITHUB_REPO=klimPaskov/Chaos-Redux
CHAOSX_AUTOMATION_REMINDER_CHANNEL_ID=1395464062367698977
CHAOSX_CONTENT_DUMP_CHANNEL_ID=1516054706286235768
CHAOSX_OBSIDIAN_VAULT_PATH=/mnt/c/Users/klimp/Documents/Chaos Redux Vault
CHAOSX_COMMUNITY_NOTES_ENABLED=true
CHAOSX_COMMUNITY_EVENT_SPECS_FOLDER=Events/Event Specs
CHAOSX_COMMUNITY_SUGGESTIONS_FOLDER=Planning/Community Suggestions
CHAOSX_COMMUNITY_EVENT_IDEAS_CHANNEL_ID=1395464994639839356

# Reaction-based server access message in #ℹ️┃info.
CHAOSX_ACCESS_REACTION_CHANNEL_ID=1396027815786188890
CHAOSX_ACCESS_REACTION_MESSAGE_ID=1526508030886154331
CHAOSX_ACCESS_REACTION_CHAOS_EMOJI_ID=1525495423949864960
CHAOSX_ACCESS_REACTION_CHAOS_EMOJI_NAME=chaosx_logo
CHAOSX_ACCESS_REACTION_MOD_EMOJI=💻
CHAOSX_ACCESS_REACTION_MEMBER_ROLE_ID=1526507892310675539
CHAOSX_ACCESS_REACTION_MODDER_ROLE_ID=1526507893837529138

# Max seconds an in-command Hermes run may execute before timing out.
CHAOSX_HERMES_TIMEOUT_SECONDS=900
# Max seconds for /admin ask. 0 means no subprocess timeout.
CHAOSX_ADMIN_ASK_TIMEOUT_SECONDS=0
CHAOSX_ADMIN_ASK_MEMORY_TURNS=5
CHAOSX_ADMIN_ASK_MEMORY_KEEP_LAST=20
# Reply-chain memory stores model-backed /ask, @ChaosX, and owner admin mention/reply turns by bot message ID.
CHAOSX_REPLY_CONTEXT_TURNS=6
# 0 means retain all stored message asks locally; set a positive number to prune per guild/channel.
CHAOSX_REPLY_MEMORY_KEEP_LAST=0
CHAOSX_ASK_MODEL=gpt-5.6-luna
CHAOSX_ASK_PROVIDER=openai-codex
CHAOSX_ASK_REASONING_EFFORT=medium
CHAOSX_OPERATOR_MODEL=gpt-5.6-luna
CHAOSX_OPERATOR_PROVIDER=openai-codex
CHAOSX_OPERATOR_REASONING_EFFORT=xhigh

# Optional local GitHub webhook receiver. Set a real secret to enable.
CHAOSX_WEBHOOK_HOST=127.0.0.1
CHAOSX_WEBHOOK_PORT=8787
CHAOSX_GITHUB_WEBHOOK_SECRET=
CHAOSX_WEBHOOK_PUBLIC_BASE_URL=

# Public community abuse/token controls.
CHAOSX_PUBLIC_ASK_LIMIT_PER_HOUR=10
CHAOSX_PUBLIC_SCRIPTED_LIMIT_PER_HOUR=20
CHAOSX_PUBLIC_PROMPT_MAX_CHARS=600
CHAOSX_MENTION_ASK_ENABLED=true
CHAOSX_ADMIN_CONTEXT_MESSAGE_LIMIT=120
